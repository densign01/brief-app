# Fastfile for Brief app

default_platform(:ios)

# API Key configuration
api_key = app_store_connect_api_key(
  key_id: "PAQ942SRH8",
  issuer_id: "0eeb23de-a487-4bdb-af96-0963eca56db7",
  key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_PAQ942SRH8.p8"),
  in_house: false
)

platform :ios do
  desc "Build iOS App Store package without uploading"
  lane :build_ios do
    build_app(
      project: "Brief.xcodeproj",
      scheme: "Brief (iOS)",
      clean: true,
      export_method: "app-store",
      output_directory: File.expand_path("~/Desktop/BriefArchives/iOS-Export"),
      output_name: "Brief.ipa"
    )
  end

  desc "Upload iOS build to App Store Connect"
  lane :upload_ios do
    upload_to_app_store(
      api_key: api_key,
      skip_screenshots: true,
      skip_metadata: true,
      ipa: File.expand_path("~/Desktop/BriefArchives/iOS-Export/Brief.ipa"),
      force: true
    )
  end

  desc "Build and upload iOS"
  lane :release_ios do
    build_ios
    upload_ios
  end
end

platform :mac do
  desc "Build macOS App Store package without uploading"
  lane :build_macos do
    build_app(
      project: "Brief.xcodeproj",
      scheme: "Brief (macOS)",
      clean: true,
      export_method: "app-store",
      output_directory: File.expand_path("~/Desktop/BriefArchives/macOS-Export"),
      output_name: "Brief"
    )
  end

  desc "Upload macOS build to App Store Connect"
  lane :upload_macos do
    upload_to_app_store(
      api_key: api_key,
      skip_screenshots: true,
      skip_metadata: true,
      pkg: File.expand_path("~/Desktop/BriefArchives/macOS-Export/Brief.pkg"),
      force: true,
      platform: "osx",
      run_precheck_before_submit: false
    )
  end

  desc "Submit uploaded macOS build to App Review"
  lane :submit_macos do
    upload_to_app_store(
      api_key: api_key,
      skip_screenshots: true,
      skip_metadata: true,
      skip_binary_upload: true,
      submit_for_review: true,
      build_number: "6",
      app_version: "1.2",
      release_notes: {
        "en-US" => "Reliability improvements for saving and sharing links:\n- Safer handling of article text and AI summaries before email delivery.\n- More reliable web-link validation in the app and share extensions.\n- More reliable email delivery infrastructure.\n- Better timeout handling and clearer send failures from share sheets."
      },
      force: true,
      platform: "osx",
      run_precheck_before_submit: false,
      automatic_release: true,
      submission_information: {
        add_id_info_uses_idfa: false,
        content_rights_contains_third_party_content: false,
        export_compliance_uses_encryption: false
      }
    )
  end

  desc "Build and upload macOS"
  lane :release_macos do
    build_macos
    upload_macos
    submit_macos
  end
end
